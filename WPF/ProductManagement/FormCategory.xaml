<Window x:Class="ProductManagement.FormCategory"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProductManagement"
        mc:Ignorable="d"
        Title="Category Management" Height="450" Width="800" WindowStartupLocation="CenterScreen" x:Name="frmCategory" Loaded="frmCategory_Loaded">

    <Border Background="#F3F4F6" Margin="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>

                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="4*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Row="0" Grid.Column="0" Content="Id" HorizontalAlignment="Right"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtId"/>
                <Label Grid.Row="1" Grid.Column="0" Content="Name" HorizontalAlignment="Right"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtName"/>
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
                    <Button x:Name="btnAdd" Content="_Add category" Width="120" Margin="0,0,5,0" Background="Yellow" FontWeight="Bold" Click="btnAdd_Click"/>
                    <Button x:Name="btnUpdate" Content="_Update category" Width="120" Margin="0,0,5,0" Background="Yellow" FontWeight="Bold" Click="btnUpdate_Click"/>
                    <Button x:Name="btnDelete" Content="_Delete category" Width="120" Margin="0,0,5,0" Background="Yellow" FontWeight="Bold" Click="btnDelete_Click"/>
                    <Button x:Name="btnClose" Content="_Close" Width="120" Margin="0,0,5,0" Background="Yellow" FontWeight="Bold" Click="btnClose_Click"/>
                </StackPanel>
            </Grid>
            <Grid Grid.Row="1" Margin="5">
                <DataGrid x:Name="dgCategory" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="dgCategory_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="1*" Header="Id" Binding="{Binding CatId}"/>
                        <DataGridTextColumn Width="4*" Header="Category name" Binding="{Binding CatName}"/>
                    </DataGrid.Columns>
                    
                </DataGrid>

            </Grid>
        </Grid>
    </Border>

</Window>
