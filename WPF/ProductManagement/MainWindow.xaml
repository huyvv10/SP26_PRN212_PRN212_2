<Window x:Class="ProductManagement.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProductManagement"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" WindowStartupLocation="CenterScreen">
    
    
        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Vertical" Margin="5" HorizontalAlignment="Center">
            <Button x:Name="btnCategory" Content="Category" Width="150" Margin="5" Background="Yellow" FontWeight="Bold" Click="btnCategory_Click"/>
            <Button x:Name="btnProduct" Content="Product Management" Width="150" Margin="5" Background="Yellow" FontWeight="Bold" Click="btnProduct_Click"/>
          
            <Button x:Name="btnClose" Content="_Close" Width="150" Margin="5" Background="Yellow" FontWeight="Bold" Click="btnClose_Click"/>
        </StackPanel>

</Window>
